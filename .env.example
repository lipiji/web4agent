# web4agent environment variables
# Copy to .env and adjust as needed

# Request timeout in seconds (default: 20)
WRT_TIMEOUT=20

# Max concurrent requests for fast strategy (default: 50)
WRT_FAST_CONCURRENCY=50

# Max concurrent requests for crawl4ai strategy (default: 10)
WRT_CRAWL4AI_CONCURRENCY=10

# Max concurrent Playwright browser pages (default: 3)
WRT_BROWSER_CONCURRENCY=3

# Minimum text length to consider a page successfully scraped (default: 300)
WRT_MIN_TEXT_LENGTH=300

# Custom User-Agent string
# WRT_USER_AGENT=Mozilla/5.0 ...

# Max characters returned to agent context before truncation (default: 8000)
WRT_AGENT_MAX_CONTENT_CHARS=8000
